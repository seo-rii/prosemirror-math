{
  "name": "@seorii/prosemirror-math",
  "version": "0.5.0",
  "description": "Schema and plugins for first-class math support in ProseMirror.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seo-rii/prosemirror-math.git"
  },
  "private": false,
  "scripts": {
    "build:check": "tsc --project tsconfig.build.json --noEmit",
    "build:dist": "npm run build:check && vite --config vite.config.lib.ts build",
    "build:docs": "npm run build:dist && cd docs-src && npm run build",
    "build": "npm run build:dist",
    "build:all": "npm run build:docs",
    "clean": "npx del dist && npx del docs",
    "serve:docs": "cd docs-src && npm run serve",
    "prepack": "npm run clean && npm run build:dist",
    "deploy": "npm run prepack && npm publish --access public --ignore-scripts"
  },
  "keywords": [
    "prosemirror",
    "math",
    "katex",
    "mathjax",
    "latex"
  ],
  "author": "Benjamin R. Bray",
  "license": "MIT",
  "peerDependencies": {
    "@tiptap/core": "^2.0.4",
    "katex": "^0.13.24",
    "prosemirror-commands": "^1.5.2",
    "prosemirror-history": "^1.3.2",
    "prosemirror-inputrules": "^1.2.1",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.19.3",
    "prosemirror-state": "^1.4.3",
    "prosemirror-transform": "^1.7.4",
    "prosemirror-view": "^1.31.7"
  },
  "peerDependenciesMeta": {
    "@tiptap/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@types/katex": "^0.16.2"
  },
  "devDependencies": {
    "@tiptap/core": "^2.0.4",
    "del-cli": "^5.0.0",
    "typescript": "5.4.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.1"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tiptap": {
      "import": "./dist/tiptap.es.js",
      "require": "./dist/tiptap.cjs",
      "types": "./dist/tiptap.d.ts"
    },
    "./style.css": "./style/index.css",
    "./math.css": "./style/math.css"
  },
  "files": [
    "dist",
    "style"
  ],
  "packageManager": "pnpm@10.30.0"
}
